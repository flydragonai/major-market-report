# --------- mmr Supabase (database with mmr_* tables) ---------
# The project where you applied the migrations under supabase/migrations.
# Service-role key (sb_secret_*) — the app reads AND writes (mmr_runs,
# mmr_responses, mmr_domain_overrides), so a readonly key won't work.
MMR_SUPABASE_URL=https://<your-project>.supabase.co
MMR_SUPABASE_KEY=sb_secret_...

# --------- Admin auth ---------
# Single shared secret protecting the report. Paste this once in the
# /unauthorized form; cookie persists for 30 days. Leave blank in local
# dev to skip the gate.
ADMIN_TOKEN=

# --------- LLM API keys (needed for the "Run scoring" button) ---------
# Pull from live-ai-visibility-score's .env if the scoring backend
# already has them — same accounts, same keys.
OPENAI_API_KEY=
GEMINI_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASS=
